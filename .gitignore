# ----- Variáveis de Ambiente e Segredos (NUNCA commitar) -----
.env
.env.local
.env.*.local
.env.development
.env.production
*.secret
secrets.json
credentials.json

# ----- Dependências Node.js -----
node_modules/
package-lock.json
yarn.lock

# ----- Logs de Ferramentas -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# ----- Build / Diretórios Temporários -----
dist/
build/
out/
.cache/
.parcel-cache/
.turbo/
coverage/
tmp/
temp/

# ----- IDEs e Editores -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.sw?

# ----- Artefatos de Sistema Operacional -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----- Pastas de Agentes / Automação (IA) -----
.agents/
stitch/

# ----- Versões Antigas -----
old/
